---
import { SITE, CONTACT, NAV } from '../config/site';

export interface Props {
  lang: 'es' | 'en';
  currentPath?: string;
}

const { lang } = Astro.props;
const currentPath = Astro.url.pathname;
---

<nav style="position:sticky;top:0;z-index:40;display:flex;align-items:center;gap:16px;padding:12px 20px;background:rgba(245,244,241,0.94);backdrop-filter:blur(8px);border-bottom:2px solid var(--color-divider)">
  <a href={lang === 'en' ? '/en/' : '/'} style="display:flex;align-items:center;gap:11px;text-decoration:none;margin-right:auto">
    <img src="/assets/lpc-logo.svg" alt={`${SITE.name} ${SITE.tagline}`} style="width:42px;height:42px;object-fit:contain" />
    <span style="display:flex;flex-direction:column;line-height:1.05">
      <span style="font-family:var(--font-heading);font-weight:800;font-size:17px;letter-spacing:-0.01em;color:var(--color-accent)">{SITE.name}</span>
      <span style="font-size:9.5px;letter-spacing:0.16em;text-transform:uppercase;color:var(--gold-deep)">{SITE.tagline}</span>
    </span>
  </a>
  <div class="nav-links" style="display:none;gap:30px;align-items:center">
    {
      NAV.map((item) => {
        const href = lang === 'en' && item.href === '/' ? '/en/' : lang === 'en' ? `/en${item.href}` : item.href;
        const isCurrent = currentPath === href;
        return (
          <a
            href={href}
            aria-current={isCurrent ? 'page' : undefined}
            style={{
              color: isCurrent ? 'var(--color-accent)' : 'var(--color-text)',
              textDecoration: 'none',
              fontSize: '14px',
              fontWeight: 600,
            }}
          >
            {lang === 'en' ? item.labelEn : item.label}
          </a>
        );
      })
    }
  </div>
  <a
    href={lang === 'en' ? '/en/contacto' : '/contacto'}
    class="btn btn-primary"
    style="white-space:nowrap"
  >
    {lang === 'es' ? 'Consulta gratis' : 'Free consultation'}
  </a>
  <a
    href="/"
    style={{
      fontSize: '12px',
      fontWeight: 700,
      textDecoration: 'none',
      padding: '4px 8px',
      color: lang === 'en' ? 'var(--color-accent)' : 'var(--color-text-muted)',
    }}
    aria-label="Switch language"
  >
    {lang === 'es' ? 'EN' : 'ES'}
  </a>
</nav>

<style>
  @media (min-width: 820px) {
    .nav-links { display: flex !important; }
  }
</style>
