---
import Layout from '../../layouts/Layout.astro';
import { SITE, CONTACT, SOCIAL } from '../../config/site';
---

<Layout
  title="Contact"
  description="Book your free consultation with LPC Services. WhatsApp, email, or online form. We'll reply within 24 hours."
  lang="en"
>
  <section style="background:var(--color-accent-800);color:#fff;padding:40px 0 42px">
    <div class="wrap">
      <span style="font-size:12px;letter-spacing:0.16em;text-transform:uppercase;color:var(--gold)">Contact</span>
      <h1 style="font-family:var(--font-heading);font-weight:800;font-size:42px;letter-spacing:-0.02em;color:#fff;margin:10px 0 0">Book your free consultation</h1>
      <p style="font-size:16px;line-height:1.6;color:rgba(255,255,255,0.82);margin:16px 0 0;max-width:52ch">We serve in Spanish, remotely, across the entire United States. We'll reply by WhatsApp or email within 24 hours.</p>
    </div>
  </section>

  <section style="padding:44px 0 52px">
    <div class="wrap contact-page-grid">
      <div>
        <span class="section-label">Direct channels</span>
        <div style="display:flex;flex-direction:column;gap:2px;margin-top:16px">
          <a href={CONTACT.whatsApp} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:13px;padding:16px;background:var(--wa);color:#fff;text-decoration:none">
            <svg viewBox="0 0 24 24" fill="currentColor" style="width:24px;height:24px;flex:none"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.71.306 1.263.489 1.694.625.712.227 1.36.195 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347M12.05 21.785h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
            <span><span style="display:block;font-family:var(--font-heading);font-weight:800;font-size:15px">WhatsApp</span><span style="display:block;font-size:13px;opacity:.9">{CONTACT.whatsAppText}</span></span>
          </a>
          <a href={`mailto:${CONTACT.email}`} style="display:flex;align-items:center;gap:13px;padding:16px;background:var(--color-surface);color:var(--color-text);text-decoration:none;border:2px solid var(--color-divider)">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold-deep)" stroke-width="1.8" style="width:24px;height:24px;flex:none"><rect x="3" y="5" width="18" height="14"/><path d="m3 6 9 7 9-7"/></svg>
            <span><span style="display:block;font-family:var(--font-heading);font-weight:800;font-size:15px">Email</span><span style="display:block;font-size:13px;color:var(--color-text-muted)">{CONTACT.email}</span></span>
          </a>
          <a href={SITE.url} target="_blank" rel="noopener" style="display:flex;align-items:center;gap:13px;padding:16px;background:var(--color-surface);color:var(--color-text);text-decoration:none;border:2px solid var(--color-divider)">
            <svg viewBox="0 0 24 24" fill="none" stroke="var(--gold-deep)" stroke-width="1.8" style="width:24px;height:24px;flex:none"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3c2.5 2.5 2.5 15 0 18M12 3c-2.5 2.5-2.5 15 0 18"/></svg>
            <span><span style="display:block;font-family:var(--font-heading);font-weight:800;font-size:15px">Website</span><span style="display:block;font-size:13px;color:var(--color-text-muted)">{SITE.url}</span></span>
          </a>
        </div>

        <div style="margin-top:26px;padding-top:20px;border-top:2px solid var(--color-divider)">
          <span style="font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-deep);font-weight:600">Business hours</span>
          <div style="display:flex;justify-content:space-between;gap:12px;font-size:14px;margin-top:14px;padding-bottom:8px;border-bottom:1px solid var(--color-divider)"><span>Monday to Friday</span><span style="font-weight:600">{CONTACT.hours.weekdays}</span></div>
          <div style="display:flex;justify-content:space-between;gap:12px;font-size:14px;margin-top:8px"><span>Saturday</span><span style="font-weight:600">By appointment only</span></div>
        </div>

        <div style="margin-top:26px;padding-top:20px;border-top:2px solid var(--color-divider)">
          <span style="font-size:12px;letter-spacing:0.14em;text-transform:uppercase;color:var(--gold-deep);font-weight:600">Follow us</span>
          <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:14px">
            <a href={SOCIAL.instagram.url} target="_blank" rel="noopener" class="tag" style="text-decoration:none">Instagram {SOCIAL.instagram.label}</a>
            <a href={SOCIAL.tiktok.url} target="_blank" rel="noopener" class="tag" style="text-decoration:none">TikTok {SOCIAL.tiktok.label}</a>
          </div>
        </div>
      </div>

      <form action="/api/contacto" method="POST" enctype="multipart/form-data" style="background:var(--color-surface);color:var(--color-text);padding:26px 22px;display:flex;flex-direction:column;gap:14px;border:2px solid var(--color-divider)">
        <h2 style="font-family:var(--font-heading);font-weight:800;font-size:20px;margin:0 0 4px">Tell us about your case</h2>
        <div class="field"><label for="c-name">Full name</label><input id="c-name" class="input" type="text" name="nombre" placeholder="Your name" required /></div>
        <div style="display:flex;gap:12px;flex-wrap:wrap">
          <div class="field" style="flex:1;min-width:140px"><label for="c-phone">WhatsApp / Phone</label><input id="c-phone" class="input" type="tel" name="tel" placeholder="+1 ___ ___ ____" /></div>
          <div class="field" style="flex:1;min-width:140px"><label for="c-email">Email</label><input id="c-email" class="input" type="email" name="email" placeholder="email@example.com" /></div>
        </div>
        <div class="field"><label for="c-case">Case type</label>
          <select id="c-case" class="input" name="caso">
            <option>Affirmative Asylum</option>
            <option>Defensive Asylum</option>
            <option>EB-2 NIW Visa</option>
            <option>SIJS (Special Immigrant Juvenile)</option>
            <option>U Visa</option>
            <option>Marriage dissolution</option>
            <option>Case planning</option>
            <option>Not sure / Other</option>
          </select>
        </div>
        <div class="field"><label for="c-msg">Briefly describe your situation</label><textarea id="c-msg" class="input" name="msg" placeholder="Your message"></textarea></div>
        <div class="field" style="display:none" aria-hidden="true">
          <input type="text" name="hp" tabindex="-1" autocomplete="off" />
        </div>
        <button type="submit" class="btn btn-primary btn-block" style="justify-content:center;padding:13px;font-size:15px;cursor:pointer">Send and request free consultation</button>
        <p style="font-size:11.5px;color:var(--color-text-muted);margin:0;text-align:center">We'll reply by WhatsApp or email within 24 hours.</p>
      </form>
    </div>
  </section>
</Layout>

<style>
  .contact-page-grid { display: grid; grid-template-columns: 1fr; gap: 28px; }
  @media (min-width: 820px) {
    .contact-page-grid { grid-template-columns: 1fr 1fr; gap: 56px; align-items: start; }
  }
</style>
