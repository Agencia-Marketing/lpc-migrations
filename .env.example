# ── LPC Services — Environment Variables ──
#
# Copy this file to .env.local for local development,
# and set these via `wrangler secret put` for production.
#
# See claude.md for the full list of rules around secrets.

# Resend API key for transactional emails
# Sign up at https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# Cloudflare Turnstile secret key
# Create a widget at https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=0x4AAAAAAAxxxxxxxxxxxxxxxxxx
TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxx

# ── Usage ──
# Local dev:  cp .env.example .env.local  (never commit .env.local)
# Production: wrangler secret put RESEND_API_KEY
#             wrangler secret put TURNSTILE_SECRET
